# MAGI COUNCIL INTELLIGENCE LINK
# Create a .env file at the root and add your keys

# External Intelligence (OpenRouter) - OpenRouter API key used by server-side proxy
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional: Twilio for real VoIP calls (optional, SDK is included)
# Set these if you want actual phone calls instead of simulated calls
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_TWIML_URL=https://handler.twilio.com/twiml/placeholder
